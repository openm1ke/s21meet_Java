APP_ENV=test
TZ=Europe/Moscow
IMAGE_REPO=ghcr.io/openm1ke/s21meet
IMAGE_TAG=build-000
PROXY_MODE=vless
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
POSTGRES_BIND_ADDR=127.0.0.1
S21AUTH_BIND_ADDR=127.0.0.1
S21EDU_BIND_ADDR=127.0.0.1
S21BOT_BIND_ADDR=127.0.0.1
S21ROCKET_BIND_ADDR=127.0.0.1
S21WEB_BIND_ADDR=127.0.0.1
WEB_EDGE_HTTP_BIND_ADDR=0.0.0.0
WEB_EDGE_HTTPS_BIND_ADDR=0.0.0.0
WEB_PUBLIC_DOMAIN=s21meet.ru
WEB_TLS_MODE=acme
WEB_TLS_EMAIL=admin@s21meet.ru
PROMETHEUS_BIND_ADDR=127.0.0.1
GRAFANA_BIND_ADDR=0.0.0.0
XRAY_CONFIG_FILE=./env/test/xray/config.json.example
SSH_TUNNEL_HOST=
SSH_TUNNEL_PORT=22
SSH_TUNNEL_USER=
SSH_TUNNEL_SOCKS_PORT=1080
SSH_TUNNEL_KEY_FILE=./env/test/ssh/id_ed25519
SSH_TUNNEL_KNOWN_HOSTS_FILE=./env/test/ssh/known_hosts
