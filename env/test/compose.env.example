APP_ENV=test
IMAGE_REPO=ghcr.io/openm1ke/s21meet
IMAGE_TAG=build-000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
POSTGRES_BIND_ADDR=0.0.0.0
S21AUTH_BIND_ADDR=0.0.0.0
S21EDU_BIND_ADDR=0.0.0.0
S21BOT_BIND_ADDR=0.0.0.0
S21ROCKET_BIND_ADDR=0.0.0.0
PROMETHEUS_BIND_ADDR=0.0.0.0
GRAFANA_BIND_ADDR=0.0.0.0
S21AUTH_JAVA_OPTS=-Xms96m -Xmx192m -XX:MaxMetaspaceSize=96m -XX:ReservedCodeCacheSize=64m -XX:+UseSerialGC -XX:+ExitOnOutOfMemoryError
S21EDU_JAVA_OPTS=-Xms128m -Xmx384m -XX:MaxMetaspaceSize=128m -XX:ReservedCodeCacheSize=96m -XX:+UseSerialGC -XX:+ExitOnOutOfMemoryError
S21BOT_JAVA_OPTS=-Xms128m -Xmx320m -XX:MaxMetaspaceSize=96m -XX:ReservedCodeCacheSize=64m -XX:+UseSerialGC -XX:+ExitOnOutOfMemoryError
S21ROCKET_JAVA_OPTS=-Xms96m -Xmx160m -XX:MaxMetaspaceSize=80m -XX:ReservedCodeCacheSize=48m -XX:+UseSerialGC -XX:+ExitOnOutOfMemoryError
